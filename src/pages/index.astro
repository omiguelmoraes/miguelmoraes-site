    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .row-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--font-size-body);
    font-weight: 400;
    color: var(--color-title);
    line-height: var(--line-height-body);
