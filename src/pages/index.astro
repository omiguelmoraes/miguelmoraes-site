  .row-label {
    font-size: var(--font-size-body);
    font-weight: 400;
    color: var(--color-title);
    line-height: var(--line-height-body);
  }

  /* Link Block — project card */
  .link-block {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 8px;
    text-decoration: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  .link-block:hover {
    border-color: #bbb;
    text-decoration: none;
  }

  .link-block-image {
    width: 150px;
    height: 90px;
    flex-shrink: 0;
    overflow: hidden;
    border-right: 1px solid var(--color-border);
  }

  .link-block-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .link-block-content {
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .link-block-title {
    font-size: var(--font-size-body);
    color: var(--color-title);
    line-height: var(--line-height-body);
  }

  .link-block-sub {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    line-height: var(--line-height-body);
  }

  .see-all {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
    margin-top: 4px;
  }
  .see-all:hover { color: var(--color-title); text-decoration: none; }

  /* Horizontal image strip */
  .row-images {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    margin-top: 8px;
    padding-bottom: 4px;
    scrollbar-width: none;
  }

  .row-images::-webkit-scrollbar {
    display: none;
  }

  .row-image {
    flex-shrink: 0;
    width: 200px;
    height: 130px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-wash);
    scroll-snap-align: start;
  }

  .row-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .lightbox.open { display: flex; }

  .lightbox img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 6px;
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 18px;
    cursor: pointer;
    padding: 4px 8px;
  }
  .lightbox-close:hover { color: #fff; }

  @media (max-width: 480px) {
    .rows--divided {
      gap: 0;
    }

    .rows--divided .row {
      flex-direction: column;
      gap: 2px;
      padding: 20px 0;
      border-bottom: 1px solid var(--color-border);
    }

    .rows--divided .row:first-child {
      padding-top: 0;
    }

    .rows--divided .row:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .row {
      flex-direction: column;
      gap: 2px;
    }

    .date {
      width: auto;
      font-size: 12px;
      color: var(--color-muted);
    }

    .row-content {
      width: 100%;
    }

    .link-block {
      width: 100%;
    }
  }
</style>
