---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { allProjects } from '../../data/projects';
---

<BaseLayout title="Projects — Miguel Moraes" description="Selected work in web design, UI/UX and front-end.">
  <div class="page">

    <nav class="nav">
      <a href="/" class="back">← Miguel Moraes</a>
    </nav>

    <header class="header">
      <h1 class="title">Projects</h1>
      <p class="sub">Selected work in web design, UI/UX and front-end.</p>
    </header>

    <div class="grid">
      {Object.entries(allProjects).map(([slug, project]) => (
        <a href={`/projects/${slug}`} class="card">
          <div class="card-image">
            <img src={project.cover} alt={project.title} />
          </div>
          <div class="card-content">
            <div class="card-meta">
              <span class="card-year">{project.year}</span>
              <span class="card-sep">·</span>
              <span class="card-category">{project.category}</span>
            </div>
            <span class="card-title">{project.title}</span>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: 48px var(--layout-padding-x) var(--layout-padding-y);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .back {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
  }
  .back:hover { color: var(--color-title); }

  .header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .title {
    font-size: var(--font-size-title);
    font-weight: 400;
    color: var(--color-title);
    line-height: var(--line-height-title);
  }

  .sub {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    line-height: var(--line-height-body);
  }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: #bbb;
    text-decoration: none;
  }

  [data-theme="dark"] .card:hover {
    border-color: #444;
  }

  .card-image {
    width: 150px;
    height: 90px;
    flex-shrink: 0;
    overflow: hidden;
    border-right: 1px solid var(--color-border);
    background: var(--color-wash);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-content {
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .card-year, .card-category {
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: 1.4;
  }

  .card-sep {
    font-size: var(--font-size-small);
    color: var(--color-border);
  }

  .card-title {
    font-size: var(--font-size-body);
    color: var(--color-title);
    line-height: var(--line-height-body);
  }

  @media (max-width: 480px) {
    .card-image {
      width: 110px;
      height: 75px;
    }
  }
</style>
