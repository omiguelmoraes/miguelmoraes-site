---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { allProjects } from '../../data/projects';
---

<BaseLayout title="Projects — Miguel Moraes" description="Selected work in web design, UI/UX and front-end.">
  <div class="page">

    <nav class="nav">
      <a href="/" class="back">← Miguel Moraes</a>
    </nav>

    <header class="header">
      <h1 class="title">Projects</h1>
      <p class="sub">Selected work in web design, UI/UX and front-end.</p>
    </header>

    <div class="grid">
      {Object.entries(allProjects).map(([slug, project]) => (
        <a href={`/projects/${slug}`} class="card">
          <div class="card-image">
            <img src={project.cover} alt={project.title} />
          </div>
          <div class="card-content">
            <span class="card-meta">{project.year} · {project.location}</span>
            <span class="card-title">{project.title}</span>
            <p class="card-summary">{project.challenge.heading}</p>
            <div class="card-tags">
              {project.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: 48px var(--layout-padding-x) var(--layout-padding-y);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .back {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
  }
  .back:hover { color: var(--color-title); }

  .header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .title {
    font-size: var(--font-size-title);
    font-weight: 400;
    color: var(--color-title);
    line-height: var(--line-height-title);
  }

  .sub {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    line-height: var(--line-height-body);
  }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: #bbb;
  }

  [data-theme="dark"] .card:hover {
    border-color: #444;
  }

  .card-image {
    width: 220px;
    flex-shrink: 0;
    overflow: hidden;
    border-right: 1px solid var(--color-border);
    background: var(--color-wash);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-content {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
  }

  .card-meta {
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: 1.4;
  }

  .card-title {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-title);
    line-height: 1.3;
  }

  .card-summary {
    font-size: var(--font-size-body);
    color: var(--color-body);
    line-height: var(--line-height-body);
    margin-top: 2px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    background: var(--color-pill-bg);
    color: var(--color-muted);
    font-size: var(--font-size-small);
    padding: 3px 10px;
    border-radius: 12px;
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .card {
      flex-direction: column;
    }
    .card-image {
      width: 100%;
      height: 180px;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
