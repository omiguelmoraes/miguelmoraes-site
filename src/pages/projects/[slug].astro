---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { allProjects } from '../../data/projects';

export function getStaticPaths() {
  return Object.keys(allProjects).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const project = allProjects[slug as keyof typeof allProjects];
const otherProjects = Object.entries(allProjects).filter(([s]) => s !== slug).slice(0, 2);
---

<BaseLayout title={`${project.title} — Miguel Moraes`}>
  <div class="page">

    <nav class="nav">
      <a href="/" class="back">← Miguel Moraes</a>
    </nav>

    <header class="header">
      <div class="meta">
        <span class="meta-item">{project.year}</span>
        <span class="meta-sep">·</span>
        <span class="meta-item">{project.location}</span>
      </div>
      <h1 class="title">{project.title}</h1>
      <div class="tags">
        {project.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="cover">
      <img src={project.cover} alt={project.title} class="lightbox-trigger" />
    </div>

    <main class="body">

      <section class="section">
        <span class="section-label">Challenge</span>
        <h2 class="section-heading">{project.challenge.heading}</h2>
        <p class="section-body">{project.challenge.body}</p>
        <div class="image-grid">
          {project.challenge.images.map((src) => (
            <div class="image-frame">
              <img src={src} alt="" class="lightbox-trigger" />
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <span class="section-label">Result</span>
        <h2 class="section-heading">{project.result.heading}</h2>
        <p class="section-body">{project.result.body}</p>
        {(('url' in project && project.url) || ('figmaUrl' in project && project.figmaUrl)) && (
          <a href={('url' in project && project.url) ? project.url : (project as any).figmaUrl} target="_blank" class="visit-link">
            View project
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          </a>
        )}
        <div class="image-grid">
          {project.result.images.map((src) => (
            <div class="image-frame">
              <img src={src} alt="" class="lightbox-trigger" />
            </div>
          ))}
        </div>
      </section>

    </main>

    <footer class="project-footer">
      <div class="footer-top">
        <span class="section-label">More projects</span>
        <div class="footer-projects">
          {otherProjects.map(([s, p]) => (
            <a href={`/projects/${s}`} class="footer-project">
              <div class="footer-project-cover">
                <img src={p.cover} alt={p.title} />
              </div>
              <span class="footer-project-title">{p.title}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="footer-links">
        <a href="/" class="home-link">← Back to home</a>
        <a href="/projects" class="home-link">See all projects →</a>
      </div>
    </footer>

  </div>
</BaseLayout>

<!-- Lightbox -->
<div id="lightbox" class="lightbox" aria-hidden="true">
  <button class="lightbox-close" aria-label="Close">✕</button>
  <img id="lightbox-img" src="" alt="" />
</div>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  document.querySelectorAll('.lightbox-trigger').forEach((img) => {
    img.addEventListener('click', () => {
      lightboxImg.src = (img as HTMLImageElement).src;
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-close')) {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  .page {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: 48px var(--layout-padding-x) var(--layout-padding-y);
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .nav { margin-bottom: 0; }

  .back {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
  }
  .back:hover { color: var(--color-title); }

  .header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: var(--line-height-body);
  }

  .meta-sep {
    font-size: var(--font-size-small);
    color: var(--color-border);
  }

  .title {
    font-size: 28px;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-title);
  }

  .cover {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-wash);
    aspect-ratio: 16/9;
    cursor: zoom-in;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-label {
    font-family: ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .section-heading {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-title);
  }

  .section-body {
    font-size: var(--font-size-body);
    color: var(--color-body);
    line-height: var(--line-height-body);
    max-width: 60ch;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-pill-bg);
    color: var(--color-muted);
    font-size: var(--font-size-small);
    padding: 3px 10px;
    border-radius: 12px;
    line-height: 1.6;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 20px;
  }

  .image-frame {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-wash);
    cursor: zoom-in;
  }

  .image-frame img {
    width: 100%;
    height: auto;
    display: block;
  }

  .visit-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--font-size-body);
    color: var(--color-title);
  }
  .visit-link:hover { text-decoration: underline; }
  .visit-link svg { opacity: 0.4; }

  /* Project footer */
  .project-footer {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-top: 48px;
    border-top: 1px solid var(--color-border);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-projects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .footer-project {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
  }

  .footer-project-cover {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-wash);
    aspect-ratio: 16/9;
  }

  .footer-project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.15s;
  }

  .footer-project:hover .footer-project-cover img { opacity: 0.8; }

  .footer-project-title {
    font-size: var(--font-size-body);
    color: var(--color-title);
    line-height: var(--line-height-body);
  }

  .footer-links {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .home-link {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
  }
  .home-link:hover { color: var(--color-title); }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .lightbox.open { display: flex; }

  .lightbox img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 6px;
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 18px;
    cursor: pointer;
    padding: 4px 8px;
  }
  .lightbox-close:hover { color: #fff; }
</style>
