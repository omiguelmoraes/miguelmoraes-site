---
import BaseLayout from '../layouts/BaseLayout.astro';

const hardware = [
  { name: 'Mac Mini M4', note: "Apple's most capable compact desktop — fast, silent, small.", href: 'https://www.apple.com/mac-mini/' },
  { name: 'MX Master 3', note: 'Best productivity mouse I\'ve used. Comfortable for long sessions.', href: 'https://www.logitech.com/products/mice/mx-master-3s.html' },
  { name: 'AOC 27" QHD', note: 'Sharp, spacious monitor for everyday design and dev work.', href: '' },
  { name: 'Aula F75', note: 'Compact 75% mechanical keyboard. Great value.', href: '' },
  { name: 'Edifier W820NB', note: 'Wireless headphones with decent noise cancellation.', href: '' },
];

const software = [
  { name: 'Figma', note: 'Design, prototyping, and brand work.', href: 'https://figma.com' },
  { name: 'Cursor', note: 'AI-powered code editor. Changed how I write code.', href: 'https://cursor.sh' },
  { name: 'Claude', note: 'AI for coding, content creation, and thinking through problems.', href: 'https://claude.ai' },
  { name: 'Obsidian', note: 'Second brain and note-taking. All my notes live here.', href: 'https://obsidian.md' },
  { name: 'Things 3', note: 'Clean, fast task and project management.', href: 'https://culturedcode.com/things/' },
  { name: 'Ghostty', note: 'Fast and minimal terminal.', href: 'https://ghostty.org' },
  { name: 'Safari', note: 'Default browser. Fast and battery-friendly on Mac.', href: '' },
  { name: 'Apple Calendar', note: 'Simple. Does the job.', href: '' },
];

const books = [
  { name: "Don't Make Me Think", note: 'Steve Krug — The classic on web usability. Essential for anyone in design.', href: '' },
  { name: 'Win Without Pitching Manifesto', note: 'Blair Enns — How to position yourself and stop competing on price.', href: '' },
  { name: 'Rework', note: 'Jason Fried & DHH — A different way to think about work and building things.', href: '' },
  { name: 'The Art of Thinking in Graphs', note: 'Visual thinking and structured problem-solving.', href: '' },
  { name: 'Princípio de UX', note: 'Daniel Furtado — UX in Portuguese, well-grounded and practical.', href: '' },
  { name: 'Fall in Love with the Problem, Not the Solution', note: 'Uri Levine — On building products that solve real problems.', href: '' },
];
---

<BaseLayout title="Uses — Miguel Moraes" description="Gear, software and books I use and recommend.">
  <div class="page">

    <nav class="nav">
      <a href="/links" class="back">← Miguel Moraes</a>
    </nav>

    <header class="header">
      <h1 class="title">Uses</h1>
      <p class="sub">Gear, software and books I use and recommend.</p>
    </header>

    <section class="section">
      <span class="section-label">Hardware</span>
      <ul class="list">
        {hardware.map(item => (
          <li class="item">
            <div class="item-text">
              <span class="item-name">{item.name}</span>
              <span class="item-note">{item.note}</span>
            </div>
            {item.href && (
              <a href={item.href} target="_blank" rel="noopener" class="item-link" aria-label={`View ${item.name}`}>
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <span class="section-label">Software</span>
      <ul class="list">
        {software.map(item => (
          <li class="item">
            <div class="item-text">
              <span class="item-name">{item.name}</span>
              <span class="item-note">{item.note}</span>
            </div>
            {item.href && (
              <a href={item.href} target="_blank" rel="noopener" class="item-link" aria-label={`View ${item.name}`}>
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <span class="section-label">Books</span>
      <ul class="list">
        {books.map(item => (
          <li class="item">
            <div class="item-text">
              <span class="item-name">{item.name}</span>
              <span class="item-note">{item.note}</span>
            </div>
            {item.href && (
              <a href={item.href} target="_blank" rel="noopener" class="item-link" aria-label={`View ${item.name}`}>
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 560px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .back {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    text-decoration: none;
  }
  .back:hover { color: var(--color-title); }

  .header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .title {
    font-size: var(--font-size-title);
    font-weight: 400;
    color: var(--color-title);
    line-height: var(--line-height-title);
  }

  .sub {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    line-height: var(--line-height-body);
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .item:last-child {
    border-bottom: none;
  }

  .item-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .item-name {
    font-size: var(--font-size-body);
    color: var(--color-title);
    line-height: 1.4;
  }

  .item-note {
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: 1.5;
  }

  .item-link {
    color: var(--color-muted);
    flex-shrink: 0;
    padding: 4px;
    transition: color 0.15s;
  }

  .item-link:hover {
    color: var(--color-title);
  }
</style>
