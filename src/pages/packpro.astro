---
const kiwify = 'https://pay.kiwify.com.br/FNeJdk9';
const instagram = 'https://instagram.com/omiguelmoraes';
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>PackPro — Templates para Freelancers</title>
  <meta name="description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos. Para de perder tempo criando do zero." />
  <link rel="canonical" href="https://miguelmoraes.pro/packpro" />
  <meta property="og:title" content="PackPro — Templates para Freelancers" />
  <meta property="og:description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos." />
  <meta property="og:url" content="https://miguelmoraes.pro/packpro" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- TICKER -->
<div class="ticker" aria-hidden="true">
  <div class="ticker-track">
    {Array(10).fill(null).map(() => (
      <><span translate="no">PackPro</span><span class="dot">·</span><span>Oferta por R$37</span><span class="dot">·</span><span>3 templates no Figma</span><span class="dot">·</span><span>Acesso imediato</span><span class="dot">·</span></>
    ))}
  </div>
</div>

<!-- HERO -->
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-left">
      <span class="eyebrow">
        <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
        Templates
      </span>
      <h1 class="hero-title">
        Documentos prontos.<br />
        Projetos fechados<br />
        mais rápido.
      </h1>
      <p class="hero-sub">Contrato, proposta e orçamento no Figma. Personalize e envie em minutos, não horas.</p>
      <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="touch-action: manipulation;">
        Quero o <span translate="no">PackPro</span> — R$37 →
      </a>
    </div>

    <div class="hero-right" aria-hidden="true">
      <div class="doc-stack">
        <div class="doc doc-back">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">PROPOSTA<br />COMERCIAL</div>
          <div class="doc-divider"></div>
          <div class="doc-lines">
            <div class="doc-line" style="width:85%"></div>
            <div class="doc-line" style="width:65%"></div>
            <div class="doc-line" style="width:90%"></div>
            <div class="doc-line" style="width:55%"></div>
            <div class="doc-line" style="width:75%"></div>
            <div class="doc-line" style="width:40%"></div>
          </div>
        </div>
        <div class="doc doc-front">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">CONTRATO DE<br />PRESTAÇÃO<br />DE SERVIÇOS</div>
          <div class="doc-divider"></div>
          <div class="doc-lines">
            <div class="doc-line" style="width:95%"></div>
            <div class="doc-line" style="width:75%"></div>
            <div class="doc-line" style="width:88%"></div>
            <div class="doc-line" style="width:60%"></div>
            <div class="doc-line" style="width:82%"></div>
            <div class="doc-line" style="width:50%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="container stats-grid">
    <div class="stat">
      <span class="stat-num">5min</span>
      <span class="stat-label">para personalizar</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <span class="stat-num">3</span>
      <span class="stat-label">templates essenciais</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <span class="stat-num">100%</span>
      <span class="stat-label">editável no Figma</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <span class="stat-num">R$37</span>
      <span class="stat-label">pagamento único</span>
    </div>
  </div>
</div>

<!-- FEATURES -->
<section class="section">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      O que vem no pack
    </span>
    <h2 class="section-title">Tudo que você precisa<br />para fechar projetos.</h2>
    <div class="features-list">
      <div class="feature-row">
        <div class="feature-num">01</div>
        <div class="feature-content">
          <h3>Template de Contrato</h3>
          <p>Linguagem clara, cláusulas essenciais. Personalize com seu nome, cliente e escopo em minutos.</p>
        </div>
        <div class="feature-tags">
          <span class="tag">Dark + Light</span>
          <span class="tag">Figma</span>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-num">02</div>
        <div class="feature-content">
          <h3>Template de Proposta Comercial</h3>
          <p>Apresentação profissional para convencer clientes antes mesmo de começar.</p>
        </div>
        <div class="feature-tags">
          <span class="tag">Dark + Light</span>
          <span class="tag">Figma</span>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-num">03</div>
        <div class="feature-content">
          <h3>Template de Orçamento</h3>
          <p>Detalhe serviços e valores com clareza. Sem planilha, sem formato amador.</p>
        </div>
        <div class="feature-tags">
          <span class="tag">Dark + Light</span>
          <span class="tag">Figma</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VALUE STACK -->
<section class="section section-alt">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      Precificação
    </span>
    <h2 class="section-title">Tudo junto, por muito menos.</h2>
    <div class="value-stack">
      <div class="stack-row">
        <span>Template de Orçamento</span>
        <span class="price-old">R$97</span>
      </div>
      <div class="stack-row">
        <span>Template de Proposta Comercial</span>
        <span class="price-old">R$147</span>
      </div>
      <div class="stack-row">
        <span>Template de Contrato</span>
        <span class="price-old">R$147</span>
      </div>
      <div class="stack-row stack-total">
        <span translate="no">Pack Pro</span>
        <span class="price-final">R$37</span>
      </div>
    </div>

    <div class="pricing-card">
      <div class="pricing-left">
        <div class="pricing-price">R$37</div>
        <p class="pricing-sub">Pague uma vez. Use em todos os seus projetos, para sempre.</p>
        <ul class="checklist" role="list">
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Acesso imediato
          </li>
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Atualizações gratuitas
          </li>
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            7 dias de garantia
          </li>
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Compatível com Figma
          </li>
        </ul>
      </div>
      <div class="pricing-right">
        <span class="pricing-badge">Oferta Exclusiva</span>
        <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="touch-action: manipulation;">
          Quero o <span translate="no">PackPro</span> — R$37 →
        </a>
        <p class="pricing-note">Sem assinatura. Sem surpresas.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      FAQ
    </span>
    <h2 class="section-title">Dúvidas frequentes</h2>
    <div class="faq">
      <details class="faq-item">
        <summary class="faq-q">Por que eu preciso do <span translate="no">PackPro</span> se já faço tudo manualmente?</summary>
        <p class="faq-a">Fazer manualmente funciona, mas custa tempo — e tempo de freelancer é dinheiro. Com o <span translate="no">PackPro</span>, você personaliza e envia em minutos, não horas.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Os templates são fáceis de personalizar?</summary>
        <p class="faq-a">Sim. Tudo foi criado no Figma, com campos claros para substituir. Troque nome, logo, cores e dados do cliente em poucos cliques.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Como isso vai me ajudar a fechar mais projetos?</summary>
        <p class="faq-a">Uma proposta bem apresentada transmite confiança. O cliente percebe profissionalismo — e isso pesa na decisão de fechar com você.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Funciona para qualquer área de atuação?</summary>
        <p class="faq-a">Sim. Os templates funcionam para designers, desenvolvedores, redatores, social media e qualquer freelancer criativo.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Eu posso usar os templates quantas vezes quiser?</summary>
        <p class="faq-a">Sim. Após a compra, o acesso é permanente. Use em quantos projetos precisar, para sempre.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">E se eu não gostar ou achar que não atende minhas necessidades?</summary>
        <p class="faq-a">Você tem 7 dias de garantia. Se não ficar satisfeito, devolvemos seu dinheiro sem perguntas.</p>
      </details>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section section-alt">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      Quem fez
    </span>
    <div class="about-grid">
      <h2 class="about-title">Mas quem sou eu afinal?</h2>
      <div class="about-content">
        <p>Desde que comecei minha jornada no Design em 2021, notei o quanto tarefas operacionais — contratos, propostas, orçamentos — ocupavam meu tempo. Eram atividades essenciais, mas que me afastavam do que realmente importava.</p>
        <p>O <span translate="no">PackPro</span> nasceu disso. Materiais prontos, práticos e adaptáveis, para você focar no que realmente gera resultado.</p>
        <div class="about-btns">
          <a href={instagram} target="_blank" rel="noopener" class="btn-ghost" style="touch-action: manipulation;">Me siga no Instagram →</a>
          <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="touch-action: manipulation;">Comprar agora →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <p>Miguel Moraes © Todos os direitos reservados.</p>
</footer>

<!-- STICKY CTA -->
<div class="sticky-cta" id="sticky-cta" role="complementary" aria-label="Compra rápida">
  <span class="sticky-cta-text">Templates prontos por R$37</span>
  <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="padding: 10px 20px; font-size: 14px; touch-action: manipulation;">
    Comprar agora →
  </a>
</div>

</body>
</html>

<script>
  const stickyCta = document.getElementById('sticky-cta')!;
  const hero = document.querySelector('.hero')!;

  const observer = new IntersectionObserver(
    ([entry]) => stickyCta.classList.toggle('visible', !entry.isIntersecting),
    { threshold: 0 }
  );
  observer.observe(hero);
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #F2F1EE;
    --bg-alt: #ECEAE6;
    --surface: #FFFFFF;
    --border: #DDDBD7;
    --text: #0D0D0D;
    --muted: #6E6D6A;
    --accent: #FF5500;
    --accent-hover: #E04A00;
    --radius: 10px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* TICKER */
  .ticker {
    background: var(--text);
    color: rgba(255,255,255,0.5);
    overflow: hidden;
    padding: 9px 0;
    font-size: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .ticker-track {
    display: flex;
    gap: 20px;
    white-space: nowrap;
    width: max-content;
    animation: ticker 30s linear infinite;
  }

  .ticker-track .dot { opacity: 0.3; }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* HERO */
  .hero {
    padding: 80px 0 64px;
    border-bottom: 1px solid var(--border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 380px;
  }

  /* DOC STACK */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .doc-stack {
    position: relative;
    width: 300px;
    height: 380px;
  }

  .doc {
    position: absolute;
    width: 280px;
    background: var(--surface);
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 1px solid var(--border);
  }

  .doc-back {
    top: 0;
    right: 0;
    transform: rotate(3.5deg);
    z-index: 1;
  }

  .doc-front {
    top: 40px;
    left: 0;
    z-index: 2;
  }

  .doc-header {
    display: flex;
    justify-content: space-between;
    font-size: 7px;
    color: #aaa;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: 8px;
    border-bottom: 1px solid #f0f0f0;
  }

  .doc-title {
    font-size: 9px;
    font-weight: 700;
    color: #111;
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  .doc-divider { height: 1px; background: #f0f0f0; }

  .doc-lines { display: flex; flex-direction: column; gap: 5px; flex: 1; }

  .doc-line { height: 5px; background: #EBEBEB; border-radius: 2px; }

  /* STATS BAR */
  .stats-bar {
    border-bottom: 1px solid var(--border);
    padding: 28px 0;
    background: var(--surface);
  }

  .stats-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    text-align: center;
  }

  .stat-num {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* SECTIONS */
  .section { padding: 80px 0; }

  .section-alt { background: var(--bg-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 40px;
  }

  /* FEATURES LIST */
  .features-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 24px 28px;
    border-bottom: 1px solid var(--border);
  }

  .feature-row:last-child { border-bottom: none; }

  .feature-num {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

  .feature-content h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }

  .feature-content p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .feature-tags {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .tag {
    font-size: 11px;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* VALUE STACK */
  .value-stack {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    margin-bottom: 24px;
  }

  .stack-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--muted);
  }

  .stack-row:last-child { border-bottom: none; }

  .price-old {
    text-decoration: line-through;
    font-size: 13px;
    color: #bbb;
  }

  .stack-total { color: var(--text); font-weight: 600; }

  .price-final {
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  /* PRICING CARD */
  .pricing-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
  }

  .pricing-price {
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .pricing-sub {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 20px;
    max-width: 280px;
  }

  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .checklist li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted);
  }

  .checklist li svg { color: var(--accent); flex-shrink: 0; }

  .pricing-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .pricing-badge {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(255,85,0,0.08);
    border: 1px solid rgba(255,85,0,0.2);
    padding: 4px 10px;
    border-radius: 20px;
  }

  .pricing-note {
    font-size: 12px;
    color: var(--muted);
  }

  /* FAQ */
  .faq {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    transition: background 0.15s;
    touch-action: manipulation;
  }

