---
// Standalone dark LP — no BaseLayout, no theme toggle
const kiwify = 'https://pay.kiwify.com.br/FNeJdk9';
const instagram = 'https://instagram.com/omiguelmoraes';
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PackPro — Templates para Freelancers</title>
  <meta name="description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos. Para de perder tempo criando do zero." />
  <link rel="canonical" href="https://miguelmoraes.pro/packpro" />
  <meta property="og:title" content="PackPro — Templates para Freelancers" />
  <meta property="og:description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos." />
  <meta property="og:url" content="https://miguelmoraes.pro/packpro" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-track">
    {Array(8).fill(null).map(() => (
      <><span>Oferta Limitada</span><span class="dot">·</span><span>R$37 Hoje!</span><span class="dot">·</span></>
    ))}
  </div>
</div>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-logo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      PackPro
    </div>
    <h1 class="hero-title">
      Templates profissionais<br />
      para freelancers<br />
      <span class="muted">que fecham projetos<br />sem perder tempo.</span>
    </h1>
    <p class="hero-sub">Contrato, proposta e orçamento prontos para personalizar e usar.</p>
    <a href={kiwify} target="_blank" rel="noopener" class="btn-primary">Quero o PackPro — R$37 →</a>
  </div>

  <!-- CSS Document Mockups -->
  <div class="mockups-wrapper">
    <div class="mockups">
      <div class="doc-wrap">
        <div class="doc">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">ORÇAMENTO</div>
          <div class="doc-divider"></div>
          <div class="doc-lines">
            <div class="doc-line" style="width:80%"></div>
            <div class="doc-line" style="width:60%"></div>
            <div class="doc-line" style="width:90%"></div>
            <div class="doc-line" style="width:50%"></div>
            <div class="doc-line" style="width:70%"></div>
            <div class="doc-line" style="width:40%"></div>
            <div class="doc-line" style="width:85%"></div>
          </div>
        </div>
        <span class="doc-label">Orçamento</span>
      </div>

      <div class="doc-wrap">
        <div class="doc">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">PROPOSTA<br />COMERCIAL</div>
          <div class="doc-divider"></div>
          <div class="doc-lines">
            <div class="doc-line" style="width:90%"></div>
            <div class="doc-line" style="width:70%"></div>
            <div class="doc-line" style="width:85%"></div>
            <div class="doc-line" style="width:55%"></div>
            <div class="doc-line" style="width:80%"></div>
            <div class="doc-line" style="width:65%"></div>
            <div class="doc-line" style="width:75%"></div>
          </div>
        </div>
        <span class="doc-label">Proposta Comercial</span>
      </div>

      <div class="doc-wrap">
        <div class="doc">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">CONTRATO DE<br />PRESTAÇÃO<br />DE SERVIÇOS</div>
          <div class="doc-divider"></div>
          <div class="doc-lines">
            <div class="doc-line" style="width:95%"></div>
            <div class="doc-line" style="width:80%"></div>
            <div class="doc-line" style="width:70%"></div>
            <div class="doc-line" style="width:90%"></div>
            <div class="doc-line" style="width:60%"></div>
            <div class="doc-line" style="width:85%"></div>
            <div class="doc-line" style="width:75%"></div>
          </div>
        </div>
        <span class="doc-label">Contrato de Serviços</span>
      </div>
    </div>
  </div>
</section>

<!-- BENEFITS -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Benefícios do PackPro</h2>
    <div class="grid-2">
      <div class="card">
        <div class="card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <h3>Economia de Tempo</h3>
        <p>Menos burocracia, mais tempo para criar.</p>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Organização</h3>
        <p>Processos claros e alinhados com seu cliente.</p>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" stroke="currentColor" stroke-width="1.5"/><path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
        <h3>Profissionalismo</h3>
        <p>Feche projetos com mais confiança.</p>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Pronto para Usar</h3>
        <p>Personalize e envie em minutos.</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="section">
  <div class="container">
    <h2 class="section-title">O que você encontra no PackPro</h2>
    <div class="features-grid">
      <div class="card feature-main">
        <h3>Templates Totalmente Editáveis</h3>
        <p>Ajuste cada detalhe no Figma. Troque cor, logo, texto — sem depender de ninguém.</p>
        <div class="feature-tags">
          <span class="tag">Figma</span>
          <span class="tag">100% Editável</span>
          <span class="tag">Dark + Light</span>
        </div>
      </div>
      <div class="card feature-small">
        <h3>Templates Essenciais</h3>
        <p>Contratos, propostas e orçamentos. Tudo que você precisa para fechar projetos.</p>
      </div>
      <div class="card feature-small">
        <h3>Modos Claro e Escuro</h3>
        <p>Escolha o estilo que combina com a sua marca.</p>
      </div>
    </div>
  </div>
</section>

<!-- VALUE STACK -->
<section class="section">
  <div class="container">
    <h2 class="section-title">O que vem no PackPro?</h2>
    <div class="value-stack">
      <div class="stack-row">
        <span>Template de Orçamento</span>
        <span class="price-old">R$97</span>
      </div>
      <div class="stack-row">
        <span>Template de Proposta Comercial</span>
        <span class="price-old">R$147</span>
      </div>
      <div class="stack-row">
        <span>Template de Contrato</span>
        <span class="price-old">R$147</span>
      </div>
      <div class="stack-row stack-total">
        <span>Pack Pro</span>
        <span class="price-final">R$37</span>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Tudo isso, por um preço acessível</h2>
    <div class="pricing-card">
      <span class="pricing-badge">Oferta Exclusiva</span>
      <div class="pricing-price">R$37</div>
      <p class="pricing-sub">Pague uma vez. Use em todos os seus projetos.</p>
      <a href={kiwify} target="_blank" rel="noopener" class="btn-primary btn-full">Quero o PackPro — R$37 →</a>
      <ul class="checklist">
        <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Acesso Imediato</li>
        <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Atualizações Gratuitas</li>
        <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Suporte Dedicado</li>
        <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>7 Dias de Garantia</li>
        <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Compatível com Figma</li>
      </ul>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Dúvidas frequentes</h2>
    <div class="faq" id="faq">
      <div class="faq-item">
        <button class="faq-q">Por que eu preciso do PackPro se já faço tudo manualmente?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Fazer manualmente funciona, mas custa tempo — e tempo de freelancer é dinheiro. Com o PackPro, você personaliza e envia em minutos, não horas.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Os templates são fáceis de personalizar?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Sim. Tudo foi criado no Figma, com campos claros para substituir. Troque nome, logo, cores e dados do cliente em poucos cliques.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Como isso vai me ajudar a fechar mais projetos?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Uma proposta bem apresentada transmite confiança. O cliente percebe profissionalismo — e isso pesa na decisão de fechar com você.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Funciona para qualquer área de atuação?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Sim. Os templates funcionam para designers, desenvolvedores, redatores, social media e qualquer freelancer criativo.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Qual o diferencial do PackPro em relação a outros modelos?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Foi feito por quem trabalha como freelancer. Cada template resolve um problema real, com linguagem clara e estrutura que funciona na prática.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Eu posso usar os templates quantas vezes quiser?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Sim. Após a compra, o acesso é permanente. Use em quantos projetos precisar, para sempre.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">E se eu não gostar ou achar que não atende minhas necessidades?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">Você tem 7 dias de garantia. Se não ficar satisfeito, devolvemos seu dinheiro sem perguntas.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Isso realmente vai economizar meu tempo?<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="faq-a">O que levaria horas para criar do zero fica pronto em menos de 5 minutos.</div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section">
  <div class="container about-wrap">
    <h2 class="section-title">Mas quem sou eu afinal?</h2>
    <p class="about-body">Desde que comecei minha jornada no Design em 2021, passando por freelas e agências, notei o quanto tarefas operacionais — criar contratos, propostas, orçamentos — ocupavam meu tempo. Eram atividades essenciais, mas que me afastavam do que realmente importava: desenvolver projetos criativos e conquistar mais clientes.</p>
    <p class="about-body">Foi daí que surgiu a ideia do PackPro. Materiais prontos, práticos e adaptáveis, pensados para acelerar seu trabalho e te ajudar a ser mais estratégico nos seus projetos.</p>
    <div class="about-btns">
      <a href={instagram} target="_blank" rel="noopener" class="btn-ghost">Me siga no Instagram →</a>
      <a href={kiwify} target="_blank" rel="noopener" class="btn-primary">Comprar agora →</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <p>Miguel Moraes © Todos os direitos reservados.</p>
</footer>

</body>
</html>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #1a1a1a;
    --surface: #242424;
    --surface-2: #2e2e2e;
    --border: rgba(255,255,255,0.08);
    --text: #ffffff;
    --muted: #888888;
    --accent: #ff5500;
    --accent-hover: #e84b00;
    --radius: 12px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* TICKER */
  .ticker {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 10px 0;
    font-size: 13px;
    color: var(--muted);
  }

  .ticker-track {
    display: flex;
    gap: 16px;
    white-space: nowrap;
    width: max-content;
    animation: ticker 24s linear infinite;
  }

  .ticker-track .dot { color: var(--border); }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* HERO */
  .hero {
    padding: 80px 0 0;
    text-align: center;
  }

  .hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hero-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 20px;
  }

  .hero-title {
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .hero-title .muted { color: #555; }

  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 420px;
  }

  /* MOCKUPS */
  .mockups-wrapper {
    margin-top: 56px;
    background: #f0f0f0;
    border-radius: 16px 16px 0 0;
    padding: 40px 24px 48px;
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
  }

  .mockups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 780px;
    margin: 0 auto;
  }

  .doc-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .doc {
    background: #ffffff;
    border-radius: 8px;
    padding: 16px;
    width: 100%;
    box-shadow: 0 2px 12px rgba(0,0,0,0.10);
    aspect-ratio: 3/4;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
  }

  .doc-header {
    display: flex;
    justify-content: space-between;
    font-size: 7px;
    color: #999;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }

  .doc-title {
    font-size: 9px;
    font-weight: 700;
    color: #111;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }

  .doc-divider {
    height: 1px;
    background: #eee;
  }

  .doc-lines {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
  }

  .doc-line {
    height: 5px;
    background: #e8e8e8;
    border-radius: 2px;
  }

  .doc-label {
    font-size: 12px;
    color: #555;
    font-weight: 500;
  }

  /* SECTIONS */
  .section {
    padding: 72px 0;
  }

  .section-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }

  /* CARDS */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }

  .card h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text);
  }

  .card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .card-icon {
    width: 36px;
    height: 36px;
    background: var(--surface-2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  /* FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 12px;
  }

  .feature-main {
    grid-column: 1 / -1;
  }

  .feature-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .tag {
    background: var(--surface-2);
    color: var(--muted);
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
  }

  /* VALUE STACK */
  .value-stack {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stack-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    color: var(--muted);
  }

  .stack-row:last-child { border-bottom: none; }

  .price-old {
    text-decoration: line-through;
    font-size: 14px;
    color: #555;
  }

  .stack-total {
    color: var(--text);
    font-weight: 600;
  }

  .price-final {
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
  }

  /* PRICING CARD */
  .pricing-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
  }

  .pricing-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 11px;
    color: var(--muted);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 20px;
  }

