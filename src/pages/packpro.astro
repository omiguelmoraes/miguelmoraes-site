---
const kiwify = 'https://pay.kiwify.com.br/FNeJdk9';
const instagram = 'https://instagram.com/omiguelmoraes';
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark" />
  <title>PackPro — Templates para Freelancers</title>
  <meta name="description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos. Para de perder tempo criando do zero." />
  <link rel="canonical" href="https://miguelmoraes.pro/packpro" />
  <meta property="og:title" content="PackPro — Templates para Freelancers" />
  <meta property="og:description" content="Contrato, proposta e orçamento prontos para personalizar e usar em minutos." />
  <meta property="og:url" content="https://miguelmoraes.pro/packpro" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>
</head>
<body>

<!-- TICKER -->
<div class="ticker" aria-hidden="true">
  <div class="ticker-track">
    {Array(10).fill(null).map(() => (
      <><span translate="no">PackPro</span><span class="dot">·</span><span>R$37 uma vez</span><span class="dot">·</span><span>3 templates no Figma</span><span class="dot">·</span><span>Acesso imediato</span><span class="dot">·</span></>
    ))}
  </div>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-content">
      <span class="eyebrow">
        <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
        Templates para Freelancers
      </span>
      <h1 class="hero-title">Documentos prontos.<br />Projetos fechados.</h1>
      <p class="hero-sub">Contrato, proposta e orçamento no Figma. Personalize e envie em minutos, não horas.</p>
      <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="touch-action: manipulation;">
        Garantir por R$37 →
      </a>
    </div>
  </div>

  <div class="hero-visual" aria-hidden="true">
    <div class="container">
      <div class="doc-row">

        <div class="doc">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">CONTRATO DE<br />PRESTAÇÃO<br />DE SERVIÇOS</div>
          <div class="doc-divider"></div>
          <div class="doc-section">
            <span class="doc-section-label">PARTES</span>
            <div class="doc-lines">
              <div class="doc-line" style="width:90%"></div>
              <div class="doc-line" style="width:72%"></div>
            </div>
          </div>
          <div class="doc-section">
            <span class="doc-section-label">ESCOPO</span>
            <div class="doc-lines">
              <div class="doc-line" style="width:95%"></div>
              <div class="doc-line" style="width:80%"></div>
              <div class="doc-line" style="width:60%"></div>
            </div>
          </div>
          <div class="doc-section">
            <span class="doc-section-label">ASSINATURA</span>
            <div class="doc-sig">
              <div class="doc-sig-line"></div>
              <div class="doc-sig-line"></div>
            </div>
          </div>
        </div>

        <div class="doc doc--featured">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">PROPOSTA<br />COMERCIAL</div>
          <div class="doc-divider"></div>
          <div class="doc-section">
            <span class="doc-section-label">SOBRE</span>
            <div class="doc-lines">
              <div class="doc-line" style="width:85%"></div>
              <div class="doc-line" style="width:65%"></div>
            </div>
          </div>
          <div class="doc-section">
            <span class="doc-section-label">ESCOPO</span>
            <div class="doc-bullets">
              <div class="doc-bullet"><span class="bullet-dot"></span><div class="doc-line" style="width:75%"></div></div>
              <div class="doc-bullet"><span class="bullet-dot"></span><div class="doc-line" style="width:60%"></div></div>
              <div class="doc-bullet"><span class="bullet-dot"></span><div class="doc-line" style="width:50%"></div></div>
            </div>
          </div>
          <div class="doc-section">
            <span class="doc-section-label">INVESTIMENTO</span>
            <div class="doc-price-row">
              <div class="doc-line" style="width:50%"></div>
              <div class="doc-price-tag">R$</div>
            </div>
          </div>
        </div>

        <div class="doc">
          <div class="doc-header">
            <span>SEU NOME / MARCA</span>
            <span>XX/XX/2025</span>
          </div>
          <div class="doc-title">ORÇAMENTO<br />DETALHADO</div>
          <div class="doc-divider"></div>
          <div class="doc-table">
            <div class="doc-table-row doc-table-head">
              <div class="doc-line" style="width:55%; height:4px;"></div>
              <div class="doc-line" style="width:20%; height:4px;"></div>
            </div>
            <div class="doc-table-row">
              <div class="doc-line" style="width:60%"></div>
              <div class="doc-line" style="width:22%"></div>
            </div>
            <div class="doc-table-row">
              <div class="doc-line" style="width:50%"></div>
              <div class="doc-line" style="width:22%"></div>
            </div>
            <div class="doc-table-row">
              <div class="doc-line" style="width:65%"></div>
              <div class="doc-line" style="width:22%"></div>
            </div>
            <div class="doc-table-row">
              <div class="doc-line" style="width:45%"></div>
              <div class="doc-line" style="width:22%"></div>
            </div>
          </div>
          <div class="doc-divider" style="margin-top:8px"></div>
          <div class="doc-total">
            <span class="doc-total-label">TOTAL</span>
            <div class="doc-price-tag doc-price-tag--accent">R$</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- FEATURES BENTO -->
<section class="section">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      O que vem no pack
    </span>
    <h2 class="section-title">Tudo que você precisa<br />para fechar projetos.</h2>
    <div class="bento">
      <div class="bento-card">
        <i class="ph ph-file-text bento-icon"></i>
        <h3 class="bento-name">Contrato de Prestação de Serviços</h3>
        <p class="bento-desc">Linguagem clara, cláusulas essenciais. Personalize com nome, cliente e escopo em minutos.</p>
      </div>
      <div class="bento-card">
        <i class="ph ph-presentation-chart bento-icon"></i>
        <h3 class="bento-name">Proposta Comercial</h3>
        <p class="bento-desc">Apresentação profissional para convencer clientes antes mesmo de começar o projeto.</p>
      </div>
      <div class="bento-card">
        <i class="ph ph-calculator bento-icon"></i>
        <h3 class="bento-name">Orçamento Detalhado</h3>
        <p class="bento-desc">Detalhe serviços e valores com clareza. Sem planilha, sem formato amador.</p>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section section-alt">
  <div class="container">
    <div class="pricing-card">
      <div class="pricing-glow" aria-hidden="true"></div>
      <span class="pricing-badge">Oferta Exclusiva</span>
      <div class="pricing-price">R$37</div>
      <p class="pricing-sub">Pague uma vez. Use em todos os seus projetos, para sempre.</p>
      <ul class="checklist" role="list">
        <li>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Acesso imediato
        </li>
        <li>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Atualizações gratuitas
        </li>
        <li>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          7 dias de garantia
        </li>
        <li>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Compatível com Figma
        </li>
      </ul>
      <a href={kiwify} target="_blank" rel="noopener" class="btn-primary btn-full" style="touch-action: manipulation;">
        Garantir por R$37 →
      </a>
      <p class="pricing-note">Sem assinatura. Sem surpresas.</p>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container">
    <span class="section-eyebrow">
      <svg width="6" height="6" viewBox="0 0 6 6" aria-hidden="true"><circle cx="3" cy="3" r="3" fill="currentColor"/></svg>
      FAQ
    </span>
    <h2 class="section-title">Dúvidas frequentes</h2>
    <div class="faq">
      <details class="faq-item">
        <summary class="faq-q">Por que eu preciso do PackPro se já faço tudo manualmente?</summary>
        <p class="faq-a">Fazer manualmente funciona, mas custa tempo — e tempo de freelancer é dinheiro. Com o <span translate="no">PackPro</span>, você personaliza e envia em minutos, não horas.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Os templates são fáceis de personalizar?</summary>
        <p class="faq-a">Sim. Tudo foi criado no Figma, com campos claros para substituir. Troque nome, logo, cores e dados do cliente em poucos cliques.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Como isso vai me ajudar a fechar mais projetos?</summary>
        <p class="faq-a">Uma proposta bem apresentada transmite confiança. O cliente percebe profissionalismo — e isso pesa na decisão de fechar com você.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Funciona para qualquer área de atuação?</summary>
        <p class="faq-a">Sim. Os templates funcionam para designers, desenvolvedores, redatores, social media e qualquer freelancer criativo.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Posso usar os templates quantas vezes quiser?</summary>
        <p class="faq-a">Sim. Após a compra, o acesso é permanente. Use em quantos projetos precisar, para sempre.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">E se eu não gostar ou achar que não atende minhas necessidades?</summary>
        <p class="faq-a">Você tem 7 dias de garantia. Se não ficar satisfeito, devolvemos seu dinheiro sem perguntas.</p>
      </details>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section section-alt">
  <div class="container">
    <div class="about-grid">
      <h2 class="about-title">Feito por quem<br />viveu o problema.</h2>
      <div class="about-content">
        <p>Desde que comecei na área de Design em 2021, percebi o quanto tarefas operacionais — contratos, propostas, orçamentos — ocupavam meu tempo. Eram essenciais, mas me afastavam do que realmente importava.</p>
        <p>O <span translate="no">PackPro</span> nasceu disso. Materiais prontos, práticos e adaptáveis, para você focar no que gera resultado.</p>
        <div class="about-btns">
          <a href={instagram} target="_blank" rel="noopener" class="btn-ghost" style="touch-action: manipulation;">Me siga no Instagram →</a>
          <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="touch-action: manipulation;">Comprar agora →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <p>Miguel Moraes © Todos os direitos reservados.</p>
</footer>

<!-- STICKY CTA -->
<div class="sticky-cta" id="sticky-cta" role="complementary" aria-label="Compra rápida">
  <span class="sticky-cta-text">Templates prontos por R$37</span>
  <a href={kiwify} target="_blank" rel="noopener" class="btn-primary" style="padding: 10px 20px; font-size: 14px; touch-action: manipulation;">
    Comprar agora →
  </a>
</div>

</body>
</html>

<script>
  const stickyCta = document.getElementById('sticky-cta')!;
  const hero = document.querySelector('.hero')!;

  const observer = new IntersectionObserver(
    ([entry]) => stickyCta.classList.toggle('visible', !entry.isIntersecting),
    { threshold: 0 }
  );
  observer.observe(hero);
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0E0D0C;
    --bg-alt: #131110;
    --surface: #1C1A16;
    --border: rgba(255,255,255,0.08);
    --border-strong: rgba(255,255,255,0.14);
    --text: #F0EDE8;
    --muted: #7A756F;
    --accent: #FF5500;
    --accent-hover: #FF6B1E;
    --radius: 12px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, .about-title, .eyebrow, .section-eyebrow, .pricing-badge, .bento-num { font-family: 'Space Grotesk', sans-serif; }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* TICKER */
  .ticker {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 10px 0;
    font-size: 12px;
    font-weight: 500;
    color: rgba(240,237,232,0.6);
  }

  .ticker-track {
    display: flex;
    gap: 20px;
    white-space: nowrap;
    width: max-content;
    animation: ticker 30s linear infinite;
  }

  .ticker-track .dot { color: var(--accent); opacity: 0.5; }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* HERO */
  .hero {
    padding-top: 96px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center top, rgba(255,85,0,0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    position: relative;
    z-index: 1;
    padding-bottom: 56px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-title {
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    max-width: 760px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 400px;
  }

  /* HERO VISUAL */
  .hero-visual {
    position: relative;
    z-index: 1;
    padding-bottom: 0;
  }

  .doc-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    align-items: end;
  }

  /* DOC CARDS */
  .doc {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px 10px 0 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.3);
  }

  .doc--featured {
    border-color: rgba(255,85,0,0.25);
    padding-top: 24px;
    margin-bottom: -12px;
    box-shadow: 0 -12px 50px rgba(255,85,0,0.08), 0 -8px 40px rgba(0,0,0,0.4);
  }

  .doc--featured::before {
    content: '';
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,85,0,0.7), transparent);
    margin: -24px -20px 12px;
  }

  .doc-header {
    display: flex;
    justify-content: space-between;
    font-size: 7px;
    color: rgba(255,130,60,0.45);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .doc-title {
    font-size: 10px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.04em;
    line-height: 1.6;
  }

  .doc-divider { height: 1px; background: rgba(255,255,255,0.06); }

  .doc-section {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .doc-section-label {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255,85,0,0.4);
    text-transform: uppercase;
  }

  .doc-lines { display: flex; flex-direction: column; gap: 5px; }
  .doc-line { height: 5px; background: rgba(255,255,255,0.07); border-radius: 2px; }

  .doc-bullets { display: flex; flex-direction: column; gap: 5px; }
  .doc-bullet { display: flex; align-items: center; gap: 5px; }
  .bullet-dot {
    width: 3px; height: 3px; border-radius: 50%;
    background: var(--accent); opacity: 0.4; flex-shrink: 0;
  }

  .doc-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .doc-price-tag {
    font-size: 8px;
    font-weight: 700;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.02em;
  }

  .doc-price-tag--accent { color: rgba(255,85,0,0.5); }

  .doc-table { display: flex; flex-direction: column; gap: 6px; }

  .doc-table-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  .doc-table-head .doc-line { background: rgba(255,255,255,0.12); }

  .doc-sig {
    display: flex;
    gap: 16px;
  }

  .doc-sig-line {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.12);
    margin-top: 12px;
  }

  .doc-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .doc-total-label {
    font-size: 7px;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* SECTIONS */
  .section { padding: 96px 0; }

  .section-alt {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 48px;
  }

  /* BENTO */
  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .bento-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .bento-card:hover {
    border-color: rgba(255,85,0,0.4);
  }

  .bento-icon {
    font-size: 24px;
    color: var(--accent);
    opacity: 0.8;
  }

  .bento-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    flex: 1;
  }

  .bento-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
  }

  /* PRICING */
  .pricing-card {
    max-width: 440px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid rgba(255,85,0,0.2);
    border-radius: 16px;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .pricing-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,85,0,0.6), transparent);
  }

  .pricing-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(255,85,0,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .pricing-badge {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(255,85,0,0.10);
    border: 1px solid rgba(255,85,0,0.2);
    padding: 4px 10px;
    border-radius: 20px;
    position: relative;
    margin-bottom: 24px;
  }

  .pricing-price {
