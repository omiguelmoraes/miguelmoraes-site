---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Miguel Moraes — Designer & Strategist',
  description = 'Designer & Strategist focused on branding, web design and UI/UX. Based in Brazil, open to remote projects.',
  image = '/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Miguel Moraes" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400&display=swap" rel="stylesheet" />
    <script is:inline>
      // Apply saved theme before render to avoid flash
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    </script>
    <script>
      import '@phosphor-icons/web/regular';
      import '@phosphor-icons/web/bold';
    </script>
  </head>
  <body>
    <button id="theme-toggle" aria-label="Toggle dark mode">
      <i id="icon-sun" class="ph ph-sun" style="font-size:16px"></i>
      <i id="icon-moon" class="ph ph-moon" style="font-size:16px;display:none"></i>
    </button>
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<script>
  const btn = document.getElementById('theme-toggle')!;
  const html = document.documentElement;

  function getTheme() {
    return html.getAttribute('data-theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  }

  const sun = document.getElementById('icon-sun')!;
  const moon = document.getElementById('icon-moon')!;

  function updateIcon(theme: string) {
    if (theme === 'dark') {
      sun.style.display = 'none';
      moon.style.display = 'block';
    } else {
      sun.style.display = 'block';
      moon.style.display = 'none';
    }
  }

  updateIcon(getTheme());

  btn.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateIcon(next);
  });
</script>

<style>
  #theme-toggle {
    position: fixed;
    top: 20px;
    right: 20px;
    background: var(--color-pill-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    color: var(--color-muted);
    padding: 8px;
    line-height: 0;
    transition: color 0.15s, background 0.15s;
    z-index: 10;
  }

  #theme-toggle:hover {
    color: var(--color-title);
    background: var(--color-wash);
  }
</style>
